# ============================================
# GLOBAL ENVIRONMENT VARIABLES
# ============================================

# Node Environment
NODE_ENV=development

# ============================================
# DATABASE
# ============================================

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edudb?schema=public"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edudb

# ============================================
# CACHE & QUEUE
# ============================================

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ============================================
# AI SERVICES
# ============================================

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# ============================================
# STORAGE
# ============================================

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edu-platform
S3_REGION=us-east-1

# ============================================
# SERVICES PORTS
# ============================================

# Core API
CORE_API_PORT=3000
CORE_API_URL=http://localhost:3000

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://localhost:3001

# User Service
USER_SERVICE_PORT=3003
USER_SERVICE_URL=http://localhost:3003

# Game Service
GAME_SERVICE_PORT=3007
GAME_SERVICE_URL=http://localhost:3007

# AI Service
AI_SERVICE_PORT=3008
AI_SERVICE_URL=http://localhost:3008

# Analytics Service
ANALYTICS_SERVICE_PORT=3009
ANALYTICS_SERVICE_URL=http://localhost:3009

# ============================================
# FRONTEND APPS
# ============================================

# Web App (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ============================================
# EXTERNAL SERVICES
# ============================================

# Email (SendGrid / AWS SES)
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com

# Push Notifications (Firebase)
FCM_SERVER_KEY=

# ============================================
# MONITORING & LOGGING
# ============================================

# Sentry
SENTRY_DSN=

# Log Level
LOG_LEVEL=debug

# ============================================
# CORS
# ============================================

CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
