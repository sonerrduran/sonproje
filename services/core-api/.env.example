# ============================================================
# Education Platform — Core API
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# PostgreSQL
DATABASE_URL="postgresql://platform:platform_dev_pass@localhost:5432/platform"
DB_POOL_SIZE=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pass

# JWT — MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_very_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_also_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
AI_MAX_TOKENS=2048

# Object Storage (MinIO dev / S3 prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=platform_admin
STORAGE_SECRET_KEY=platform_minio_pass
STORAGE_BUCKET=platform-assets

# Email (optional for dev, required for prod)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@platform.local
